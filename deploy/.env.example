APP_PORT=8080
# 部署脚本会自动使用当前项目根目录下的 uploads 目录；手动配置时请填写绝对路径
HOST_UPLOAD_DIR=/path/to/project/uploads

# USE_EXTERNAL_DB=1 表示连接外部数据库；0 表示启动 Docker MySQL 容器
USE_EXTERNAL_DB=1
MYSQL_HOST=db.example.com
MYSQL_PORT=3306
MYSQL_DATABASE=ytbx
MYSQL_USER=ytbx
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=
MYSQL_URL=jdbc:mysql://db.example.com:3306/ytbx?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

AUTH_TOKEN_SECRET=change_me_to_a_long_random_secret
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

PRODUCT_IMAGE_PATH=products
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp
YTBX_SQL_INIT_MODE=never

ENABLE_NGINX=1
SERVER_NAME=example.com
